# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Secrets — never commit
.env

# Local vector DB artifacts (legacy)
.chroma/

# Large raw data — don't commit
data/raw/

# Processed data — keep for deployment
!data/processed/
!data/manifest.json

# Logs
*.log
logs/

# Node / Next.js
node_modules/
apps/web/.next/
apps/web/.env.local

# IDE / local tooling
.cursor/

# App Runner deploy temp (may contain secrets)
infra/apprunner/.tmp/

# Large chunk/node files (regenerate via ingestion)
data/processed/chunks/chunks_node.jsonl
data/processed/hts/hts_nodes.jsonl
