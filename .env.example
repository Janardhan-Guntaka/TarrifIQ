# Copy to .env and fill in values. Never commit .env.

# OpenAI (required for embeddings + LLM)
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (Supabase → Settings → Database → Connection string)
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Optional: JWT secret for FastAPI auth (Supabase → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_LLM_CONCURRENT=5
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSIONS=1536

# CORS (comma-separated — add Vercel URL after deploy)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# AWS (Phase 5+ — leave empty for local-only)
AWS_REGION=us-east-1
S3_BUCKET_HTS_RELEASES=
