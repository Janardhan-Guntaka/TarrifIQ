# Copy to .env and fill in values. Never commit .env.
#
# ── Local dev (Windows) ─────────────────────────────────────────────────────
# Use SUPABASE_DB_PASSWORD + DATABASE_CONNECTION (auto-builds pooler URL).
# Run: python scripts/test_db_connection.py  to find a working mode.
#
# ── Cloud (AWS App Runner / GitHub Secrets) ───────────────────────────────────
# Use explicit DATABASE_URL with "direct" connection from Supabase → Connect.
# See env/cloud.env.example

# OpenAI (required for embeddings + LLM)
OPENAI_API_KEY=

# Supabase API (public — safe for frontend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Supabase Postgres — local: auto-build from password + mode
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_REGION=us-east-1
SUPABASE_DB_PASSWORD=
# pooler-session (port 5432) | pooler-transaction (6543) | direct
# Run: python scripts/test_db_connection.py to auto-detect on your network
DATABASE_CONNECTION=direct

# Optional override — use for AWS/GitHub when you paste the dashboard URI exactly
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_LLM_CONCURRENT=5
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSIONS=1536

# CORS — add your Vercel URL after deploy
CORS_ORIGINS=http://localhost:3000

# AWS (leave empty for local-only)
AWS_REGION=us-east-1
S3_BUCKET_HTS_RELEASES=
